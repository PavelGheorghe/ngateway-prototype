<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Manage domains</title>
  <style>
    html, body { margin: 0; min-height: 100%; height: 100%; font-family: system-ui, sans-serif; }
    html, body.embed-manage-domains-root {
      background: transparent;
    }
    body.embed-manage-domains-root {
      box-sizing: border-box;
      min-height: 100%;
      height: 100%;
      margin: 0;
      color: #0f172a;
    }
    .embed-manage-domains-backdrop {
      min-height: 100%;
      min-height: 100dvh;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      box-sizing: border-box;
      background: rgba(15, 23, 42, 0.45);
    }
    .embed-manage-domains-modal {
      width: 100%;
      max-width: 640px;
      max-height: min(92vh, calc(100dvh - 2rem));
      overflow: auto;
      -webkit-overflow-scrolling: touch;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.45);
      padding: 1.5rem 1.5rem 2rem;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }
    .embed-modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
      flex-shrink: 0;
    }
    .embed-modal-header h1 {
      margin: 0;
      font-size: 1.35rem;
      font-weight: 600;
    }
    .embed-modal-close {
      flex-shrink: 0;
      width: 2.25rem;
      height: 2.25rem;
      padding: 0;
      border: 0;
      background: transparent;
      color: #64748b;
      font-size: 1.75rem;
      line-height: 1;
      cursor: pointer;
      border-radius: 8px;
    }
    .embed-modal-close:hover {
      background: #f1f5f9;
      color: #0f172a;
    }
    .muted { color: #64748b; font-size: 0.9rem; line-height: 1.45; }
    .err { color: #b91c1c; font-size: 0.9rem; }
    ul.domain-list {
      list-style: none;
      margin: 0;
      padding: 0;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      overflow: hidden;
    }
    ul.domain-list li {
      padding: 0.65rem 0.85rem;
      border-bottom: 1px solid #e2e8f0;
      font-size: 0.95rem;
      word-break: break-all;
    }
    ul.domain-list li:last-child { border-bottom: 0; }
  </style>
</head>
<body class="embed-manage-domains-root">
  <div class="embed-manage-domains-backdrop">
    <div class="embed-manage-domains-modal" role="dialog" aria-modal="true" aria-labelledby="manageDomainsTitle">
      <header class="embed-modal-header">
        <h1 id="manageDomainsTitle">Manage domains</h1>
        <button type="button" class="embed-modal-close" id="manageDomainsDismiss" aria-label="Close">×</button>
      </header>
      <p class="muted" id="manageDomainsStatus">Loading…</p>
      <ul class="domain-list" id="manageDomainsList" hidden></ul>
    </div>
  </div>

  <script>
(function () {
  function postToParent(msg) {
    if (window.parent === window) return;
    window.parent.postMessage(msg, '*');
  }

  document.getElementById('manageDomainsDismiss').addEventListener('click', function () {
    postToParent({ type: 'PUNTU_MANAGE_DOMAINS_CLOSE' });
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      postToParent({ type: 'PUNTU_MANAGE_DOMAINS_CLOSE' });
    }
  });

  var statusEl = document.getElementById('manageDomainsStatus');
  var listEl = document.getElementById('manageDomainsList');

  fetch('/api/domains', { credentials: 'include', headers: { 'Accept': 'application/json' } })
    .then(function (r) {
      if (!r.ok) throw new Error('Request failed');
      return r.json();
    })
    .then(function (data) {
      if (!data || !data.success) {
        statusEl.textContent = 'Could not load domains.';
        statusEl.className = 'err';
        return;
      }
      var domains = data.domains || [];
      statusEl.hidden = true;
      statusEl.textContent = '';
      listEl.innerHTML = '';
      if (domains.length === 0) {
        statusEl.hidden = false;
        statusEl.className = 'muted';
        statusEl.textContent = 'No domains registered through Puntu yet.';
        return;
      }
      domains.forEach(function (row) {
        var fq = (row.domainFqdn || '').trim();
        if (!fq) return;
        var li = document.createElement('li');
        li.textContent = fq;
        listEl.appendChild(li);
      });
      listEl.hidden = false;
    })
    .catch(function () {
      statusEl.textContent = 'Could not load domains.';
      statusEl.className = 'err';
    });
})();
  </script>
</body>
</html>
